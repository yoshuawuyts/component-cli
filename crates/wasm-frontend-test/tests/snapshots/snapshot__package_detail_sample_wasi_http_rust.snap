    }
    /* Card hover — pop out with scale, shadow, and strong border */
    .card-lift {
      transition: transform 0.1s ease-out, box-shadow 0.1s ease-out;
      transform-origin: center center;
    }
    /* Prose styling for rendered markdown documentation */
